---
const currentPath = Astro.url.pathname;

const tabs = [
  { href: '/', label: 'ホーム', d: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0h4' },
  { href: '/record/', label: '記録', d: 'M12 4v16m8-8H4' },
  { href: '/stock/', label: '株式', d: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6' },
  { href: '/settings/', label: '設定', d: 'M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4' },
];
---

<nav class="fixed bottom-0 left-0 right-0 bg-[#161a22] border-t border-[#2a2f3e] z-50" style="padding-bottom: env(safe-area-inset-bottom, 0)">
  <div class="max-w-[430px] mx-auto flex">
    {tabs.map((tab) => {
      const isActive = tab.href === '/' ? currentPath === '/' : currentPath.startsWith(tab.href);
      return (
        <a
          href={tab.href}
          class={`flex-1 flex flex-col items-center gap-0.5 py-2.5 text-xs font-medium transition-colors ${
            isActive ? 'text-[#00d4a0]' : 'text-[#8b8fa3]'
          }`}
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d={tab.d} />
          </svg>
          <span>{tab.label}</span>
        </a>
      );
    })}
  </div>
</nav>
